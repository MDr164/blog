---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumbs from "../components/ui/Breadcrumbs.astro";
import BlogEntry from "../components/blog/BlogEntry.astro";
import FeaturedPost from "../components/blog/FeaturedPost.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../lib/constants";

const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const featuredPost = posts[0];
const remainingPosts = posts.slice(1);

const icons = ["description", "terminal", "bug_report", "monitoring", "code", "memory", "dns", "hub"];
const iconColors = ["text-primary-container", "text-primary-container", "text-secondary", "text-tertiary", "text-primary-container", "text-secondary", "text-tertiary", "text-primary-container"];
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <Breadcrumbs
    segments={[
      { label: "root", href: "/" },
      { label: "src" },
      { label: "blog" },
    ]}
    meta={[
      { label: "entries", value: `${posts.length}_Entries`, icon: "dot" },
      { label: "updated", value: "Just now", icon: "history" },
    ]}
  />

  <!-- Page title -->
  <div class="mb-12">
    <h1 class="font-headline text-4xl md:text-5xl font-bold tracking-tight text-on-surface mb-2">
      Technical Journal
    </h1>
    <p class="text-on-surface-variant font-mono text-sm">
      Firmware, hardware, and systems engineering notes.
    </p>
  </div>

  <!-- Blog index grid -->
  {posts.length > 0 ? (
    <div class="grid grid-cols-1 gap-1" role="list">
      {posts.map((post, i) => (
        <div role="listitem">
          <BlogEntry
            post={post}
            icon={icons[i % icons.length]}
            iconColor={iconColors[i % iconColors.length]}
          />
        </div>
      ))}
    </div>
  ) : (
    <div class="text-center py-16">
      <span class="material-symbols-outlined text-4xl text-muted mb-4">edit_note</span>
      <p class="text-on-surface-variant font-mono text-sm">No posts published yet.</p>
    </div>
  )}

  <!-- Featured section -->
  {featuredPost && <FeaturedPost post={featuredPost} />}
</BaseLayout>
