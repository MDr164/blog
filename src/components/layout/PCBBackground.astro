---
// Subtle PCB trace pattern background decoration
---

<div class="fixed inset-0 pointer-events-none opacity-[0.03] z-[-1]" aria-hidden="true">
  <svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%">
    <pattern id="pcb-grid" patternUnits="userSpaceOnUse" width="100" height="100">
      <path d="M 100 0 L 0 0 0 100" fill="none" stroke="#89b4fa" stroke-width="1" />
      <circle cx="0" cy="0" r="2" fill="#89b4fa" />
      <path d="M 50 50 L 50 100 M 50 50 L 100 50" fill="none" stroke="#89b4fa" stroke-width="0.5" />
    </pattern>
    <rect fill="url(#pcb-grid)" width="100%" height="100%" />
  </svg>
</div>
