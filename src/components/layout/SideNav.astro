---
import { getCollection } from "astro:content";

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const navItems = [
  { icon: "folder_open", label: "Explorer", href: "/" },
  { icon: "article", label: "Blog", href: "/blog" },
];

const bottomItems = [
  { icon: "code", label: "Projects", href: "/projects" },
  { icon: "person", label: "About", href: "/about" },
];

function isNavActive(href: string): boolean {
  if (href === "/blog") return currentPath.startsWith("/blog");
  if (href === "/") return currentPath === "/";
  return currentPath.startsWith(href);
}

function toFilename(id: string): string {
  return id
    .split("/")
    .pop()!
    .replace(/-/g, "_")
    .replace(/\b\w/g, (c) => c.toUpperCase())
    + ".md";
}
---

<aside
  id="sidenav"
  class="fixed left-0 top-14 h-[calc(100vh-3.5rem-1.5rem)] w-64 hidden md:flex flex-col border-r border-primary-container/5 bg-surface-container-low z-40"
>
  <div class="p-4 flex flex-col gap-6 h-full py-4 overflow-y-auto">
    <!-- Workspace header -->
    <div>
      <div class="flex items-center justify-between mb-4">
        <span class="font-mono text-xs tracking-widest uppercase text-on-surface-variant">Workspace</span>
        <span class="text-[10px] font-mono text-primary/60">main</span>
      </div>

      <!-- Primary nav -->
      <nav class="space-y-1" aria-label="Sidebar navigation">
        {navItems.map((item) => (
          <a
            href={item.href}
            class:list={[
              "flex items-center gap-3 px-3 py-2 font-mono text-xs tracking-widest uppercase transition-all duration-150 ease-in-out",
              isNavActive(item.href)
                ? "bg-surface-container-high text-primary-container border-l-2 border-primary-container"
                : "text-muted hover:bg-surface-container hover:text-text-light",
            ]}
          >
            <span class="material-symbols-outlined text-sm">{item.icon}</span>
            {item.label}
          </a>
        ))}
      </nav>
    </div>

    <!-- Project files -->
    <div class="mt-4">
      <span class="font-mono text-[10px] tracking-widest uppercase text-on-surface-variant/40 px-3">
        Recent_Posts
      </span>
      <div class="mt-2 space-y-1">
        {posts.slice(0, 8).map((post) => (
          <a
            href={`/blog/${post.id}`}
            class:list={[
              "flex items-center gap-2 px-6 py-1 text-xs font-mono transition-colors",
              currentPath === `/blog/${post.id}`
                ? "text-primary"
                : "text-on-surface-variant/80 hover:text-primary",
            ]}
          >
            <span class="text-primary-container text-[10px]">#</span>
            <span class="truncate">{toFilename(post.id)}</span>
          </a>
        ))}
      </div>
    </div>

    <!-- Bottom nav -->
    <div class="mt-auto pt-4 border-t border-outline-variant/10">
      {bottomItems.map((item) => (
        <a
          href={item.href}
          class:list={[
            "flex items-center gap-3 px-3 py-2 font-mono text-xs tracking-widest uppercase transition-all duration-150 ease-in-out",
            isNavActive(item.href)
              ? "bg-surface-container-high text-primary-container border-l-2 border-primary-container"
              : "text-muted hover:bg-surface-container hover:text-text-light",
          ]}
        >
          <span class="material-symbols-outlined text-sm">{item.icon}</span>
          {item.label}
        </a>
      ))}
    </div>
  </div>
</aside>
